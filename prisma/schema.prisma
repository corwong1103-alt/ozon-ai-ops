generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  pending
  approved
  expired
  suspended
}

enum UserPlan {
  starter
  pro
  vip
}

enum ProductSource {
  ozon
  source_1688 @map("1688")
  manual
}

enum ProductStatus {
  draft
  translated
  image_generated
  video_generated
  uploaded
}

enum SocialPlatform {
  tiktok
  instagram
  vk
}

enum SocialAccountStatus {
  connected
  disconnected
}

enum SocialMediaType {
  image
  video
}

enum SocialPostStatus {
  draft
  queued
  published
  failed
}

enum CustomerMessageCategory {
  presale
  logistics
  refund
  review_alert
  inventory_alert
}

enum CustomerMessageStatus {
  pending
  suggested
  replied
  alert
}

enum TaskType {
  collect
  research
  translate
  image
  video
  upload
  social_post
  social_video
  social_publish
  customer_message
  auto_reply
  alert
}

enum TaskStatus {
  queued
  processing
  success
  failed
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String
  role            UserRole         @default(user)
  status          UserStatus       @default(pending)
  plan            UserPlan         @default(starter)
  expiresAt       DateTime?
  credits         AiCredits?
  sessions        Session[]
  stores          Store[]
  products        Product[]
  taskLogs        TaskLog[]
  socialAccounts  SocialAccount[]
  socialPosts     SocialPost[]
  customerMessages CustomerMessage[]
  adminActions    AdminActionLog[] @relation("AdminActions")
  targetActions   AdminActionLog[] @relation("TargetUserActions")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AiCredits {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageCredits   Int      @default(0)
  videoCredits   Int      @default(0)
  monthlyResetAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Store {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  ozonStoreId String
  ozonClientId String
  apiKeyEncrypted String
  products    Product[]
  taskLogs    TaskLog[]
  customerMessages CustomerMessage[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Product {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId     String?
  store       Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  source      ProductSource @default(manual)
  title       String
  description String
  price       Decimal       @db.Decimal(12, 2)
  images      Json          @default("[]")
  status      ProductStatus @default(draft)
  socialPosts SocialPost[]
  taskLogs    TaskLog[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([storeId])
  @@index([status])
}

model SocialAccount {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform    SocialPlatform
  status      SocialAccountStatus @default(disconnected)
  accountName String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([userId, platform])
  @@index([userId])
}

model SocialPost {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  platform  SocialPlatform
  content   String
  mediaType SocialMediaType
  status    SocialPostStatus @default(draft)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
  @@index([productId])
}

model CustomerMessage {
  id             String                  @id @default(cuid())
  userId         String
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId        String?
  store          Store?                  @relation(fields: [storeId], references: [id], onDelete: SetNull)
  customerName   String
  message        String
  category       CustomerMessageCategory
  suggestedReply String?
  status         CustomerMessageStatus   @default(pending)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([userId])
  @@index([storeId])
  @@index([category])
}

model TaskLog {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId    String?
  store      Store?     @relation(fields: [storeId], references: [id], onDelete: SetNull)
  productId  String?
  product    Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  type       TaskType
  status     TaskStatus @default(queued)
  creditCost Int        @default(0)
  message    String
  metadata   Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model AdminActionLog {
  id           String   @id @default(cuid())
  adminId      String
  admin        User     @relation("AdminActions", fields: [adminId], references: [id], onDelete: Cascade)
  targetUserId String
  targetUser   User     @relation("TargetUserActions", fields: [targetUserId], references: [id], onDelete: Cascade)
  actionType   String
  message      String
  createdAt    DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
}
