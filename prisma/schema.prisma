generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  pending
  approved
  expired
  suspended
}

enum UserPlan {
  starter
  pro
  vip
}

enum ProductSource {
  ozon
  ozon_market
  source_1688 @map("1688")
  manual
}

/// V3 商品生命周期 9 阶段
enum ProductStatus {
  discovered        // 发现（原 draft）
  favorited         // 收藏
  in_product_center // 已入商品中心
  optimizing        // 优化中（原 translated/image_generated）
  optimized         // 已优化（原 video_generated）
  ready_to_publish  // 待发布
  published         // 已发布（原 uploaded）
  promoted          // 已推广
  archived          // 已归档
}

enum SocialPlatform {
  tiktok
  instagram
  vk
  wibus
}

enum SocialAccountStatus {
  connected
  disconnected
}

enum SocialMediaType {
  image
  video
}

/// V3 内容中心 5 阶段状态机 + failed
enum SocialPostStatus {
  draft          // 草稿
  pending_review // 待审核
  ready          // 待发布
  published      // 已发布
  scheduled      // 定时发布
  failed         // 发布失败
}

enum IntegrationProvider {
  dashscope
  ozon_market
  source_1688
  vk
  wibus
}

enum IntegrationStatus {
  configured
  disconnected
  error
}

enum CustomerMessageCategory {
  presale
  logistics
  refund
  review_alert
  inventory_alert
}

enum CustomerMessageStatus {
  pending
  suggested
  replied
  alert
}

enum TaskType {
  collect
  research
  translate
  image
  video
  upload
  social_post
  social_video
  social_publish
  customer_message
  auto_reply
  alert
}

enum TaskStatus {
  queued
  processing
  success
  failed
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String
  role            UserRole         @default(user)
  status          UserStatus       @default(pending)
  plan            UserPlan         @default(starter)
  expiresAt       DateTime?
  credits         AiCredits?
  sessions        Session[]
  stores          Store[]
  products        Product[]
  taskLogs        TaskLog[]
  integrations    ApiIntegration[]
  socialAccounts  SocialAccount[]
  socialPosts     SocialPost[]
  customerMessages CustomerMessage[]
  adminActions    AdminActionLog[] @relation("AdminActions")
  targetActions   AdminActionLog[] @relation("TargetUserActions")
  researchTasks   ResearchTask[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([role])
}

model ApiIntegration {
  id              String              @id @default(cuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        IntegrationProvider
  status          IntegrationStatus   @default(configured)
  accountLabel    String?
  publicConfig    Json                @default("{}")
  secretEncrypted String?
  lastCheckedAt   DateTime?
  lastMessage     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AiCredits {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageCredits   Int      @default(0)
  videoCredits   Int      @default(0)
  monthlyResetAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Store {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  ozonStoreId String
  ozonClientId String
  apiKeyEncrypted String
  products    Product[]
  taskLogs    TaskLog[]
  customerMessages CustomerMessage[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Product {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId     String?
  store       Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  source      ProductSource @default(manual)
  sourceProductId String?
  offerId     String?
  researchKeyword String?
  title       String
  description String
  price       Decimal       @db.Decimal(12, 2)
  currency    String        @default("CNY")
  images      Json          @default("[]")
  status      ProductStatus @default(discovered)
  socialPosts SocialPost[]
  taskLogs    TaskLog[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([source])
  @@index([sourceProductId])
}

model SocialAccount {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform    SocialPlatform
  status      SocialAccountStatus @default(disconnected)
  accountName String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([userId, platform])
  @@index([userId])
}

model SocialPost {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  platform  SocialPlatform
  content   String
  mediaType SocialMediaType
  status    SocialPostStatus @default(draft)
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([status])
}

model CustomerMessage {
  id             String                  @id @default(cuid())
  userId         String
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId        String?
  store          Store?                  @relation(fields: [storeId], references: [id], onDelete: SetNull)
  customerName   String
  message        String
  category       CustomerMessageCategory
  suggestedReply String?
  status         CustomerMessageStatus   @default(pending)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([userId])
  @@index([storeId])
  @@index([category])
}

model TaskLog {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId    String?
  store      Store?     @relation(fields: [storeId], references: [id], onDelete: SetNull)
  productId  String?
  product    Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  type       TaskType
  status     TaskStatus @default(queued)
  creditCost Int        @default(0)
  message    String
  metadata   Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model AdminActionLog {
  id           String   @id @default(cuid())
  adminId      String
  admin        User     @relation("AdminActions", fields: [adminId], references: [id], onDelete: Cascade)
  targetUserId String
  targetUser   User     @relation("TargetUserActions", fields: [targetUserId], references: [id], onDelete: Cascade)
  actionType   String
  message      String
  createdAt    DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
}

/// Ozon 市场搜索结果缓存。keyword+category 组合为唯一键，TTL 30 分钟。
/// P0-1：同关键词重复搜索直接命中缓存，跳过 Apify 调用。
model MarketSearchCache {
  id           String   @id @default(cuid())
  keyword      String
  category     String   @default("")
  result       Json
  productCount Int
  source       String   @default("apify")
  hitCount     Int      @default(0)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([keyword, category])
  @@index([keyword])
  @@index([expiresAt])
}

/// Ozon 市场搜索异步任务。P0-2：首次搜索不阻塞页面，后台执行 Apify。
/// 复用 TaskStatus enum（queued/processing/success/failed）。
model ResearchTask {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyword      String
  category     String      @default("")
  status       TaskStatus  @default(queued)
  result       Json?
  productCount Int?
  errorMessage String?
  apifyRunId   String?
  fromCache    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([keyword])
  @@index([keyword, category, status])
}

/// 跨平台采集源商品（Ozon / 1688 / Wildberries 等）。导入前的中立存储层。
/// 与 Product（内部商品池）解耦：搜索结果先落 SourceProduct，用户确认后才转成 Product。
/// 唯一约束 source + sourceProductId，防止同一源商品重复导入。
model SourceProduct {
  id                 String    @id @default(cuid())
  source             String    // "1688" / "ozon_market" / "ozon" / "wildberries"
  sourceProductId    String    // 源平台商品 ID（1688 offer id / Ozon sku）
  title              String
  image              String?
  images             Json      @default("[]")
  price              Decimal?  @db.Decimal(12, 2)
  currency           String    @default("CNY")
  supplier           String?
  supplierLevel      String?
  sales              Int       @default(0)
  rating             Decimal?  @db.Decimal(4, 2)
  productUrl         String?
  researchKeyword    String?
  importedBy         String?   // 已转成内部 Product 的用户 ID（null = 未导入）
  importedProductId  String?   // 对应内部 Product.id（null = 未导入）
  rawData            Json      @default("{}")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([source, sourceProductId])
  @@index([source])
  @@index([sourceProductId])
  @@index([importedBy])
  @@index([researchKeyword])
}
